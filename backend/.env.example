# Neon PostgreSQL (serverless)
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Local PostgreSQL fallback:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticket_booking?schema=public"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000

# Seat hold TTL in minutes
SEAT_HOLD_TTL_MINUTES=10

# Email (Mailtrap for dev, any SMTP for prod)
EMAIL_HOST="sandbox.smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="noreply@ticketbook.com"

# Frontend URL for email links
FRONTEND_URL="http://localhost:5173"
