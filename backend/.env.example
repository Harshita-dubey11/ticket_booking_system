# Neon PostgreSQL (serverless)
# Get your connection string from https://neon.tech → Project → Connection Details
# Use the pooled connection string (?pgbouncer=true) if using serverless functions
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/ticket_booking?sslmode=require"

# Local PostgreSQL fallback:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticket_booking?schema=public"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000
