generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  organiser
  admin
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(customer)
  createdAt    DateTime @default(now()) @map("created_at")

  events    Event[]     @relation("EventCreator")
  bookings  Booking[]
  heldSeats ShowSeat[]  @relation("HeldSeats")
  waitlist  Waitlist[]

  @@map("users")
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String?
  rows      Int
  columns   Int
  createdAt DateTime @default(now()) @map("created_at")

  seatCategories SeatCategory[]
  seats          Seat[]
  events         Event[]

  @@map("venues")
}

model SeatCategory {
  id          String @id @default(uuid())
  venueId     String @map("venue_id")
  name        String
  color       String
  description String?

  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  seats         Seat[]
  eventPricings EventPricing[]
  waitlist      Waitlist[]

  @@map("seat_categories")
}

model Seat {
  id         String @id @default(uuid())
  venueId    String @map("venue_id")
  categoryId String @map("category_id")
  rowLabel   String @map("row_label")
  colNumber  Int    @map("col_number")
  label      String

  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  category  SeatCategory @relation(fields: [categoryId], references: [id])
  showSeats ShowSeat[]

  @@map("seats")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String
  venueId     String   @map("venue_id")
  date        DateTime
  duration    Int
  createdBy   String   @map("created_by")
  posterUrl   String?  @map("poster_url")
  createdAt   DateTime @default(now()) @map("created_at")

  venue         Venue          @relation(fields: [venueId], references: [id])
  creator       User           @relation("EventCreator", fields: [createdBy], references: [id])
  eventPricings EventPricing[]
  showSeats     ShowSeat[]
  bookings      Booking[]
  waitlist      Waitlist[]

  @@map("events")
}

model EventPricing {
  id         String  @id @default(uuid())
  eventId    String  @map("event_id")
  categoryId String  @map("category_id")
  price      Decimal @db.Decimal(10, 2)

  event    Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category SeatCategory @relation(fields: [categoryId], references: [id])

  @@map("event_pricings")
}

model ShowSeat {
  id        String    @id @default(uuid())
  eventId   String    @map("event_id")
  seatId    String    @map("seat_id")
  status    String    @default("available")
  heldBy    String?   @map("held_by")
  heldAt    DateTime? @map("held_at")
  heldUntil DateTime? @map("held_until")
  bookingId String?   @map("booking_id")

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seat    Seat     @relation(fields: [seatId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
  bookingSeat BookingSeat?
  heldByUser User? @relation("HeldSeats", fields: [heldBy], references: [id])

  @@map("show_seats")
}

model Booking {
  id          String   @id @default(uuid())
  reference   String   @unique
  userId      String   @map("user_id")
  eventId     String   @map("event_id")
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)
  status      String   @default("pending")
  qrCode      String?  @map("qr_code")
  createdAt   DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  event        Event         @relation(fields: [eventId], references: [id])
  showSeats    ShowSeat[]
  bookingSeats BookingSeat[]

  @@map("bookings")
}

model BookingSeat {
  id          String  @id @default(uuid())
  bookingId   String  @map("booking_id")
  showSeatId  String  @unique @map("show_seat_id")
  priceAtTime Decimal @map("price_at_time") @db.Decimal(10, 2)

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  showSeat ShowSeat @relation(fields: [showSeatId], references: [id])

  @@map("booking_seats")
}

model Waitlist {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  eventId      String    @map("event_id")
  categoryId   String    @map("category_id")
  status       String    @default("waiting")
  offeredAt    DateTime? @map("offered_at")
  offeredUntil DateTime? @map("offered_until")
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User          @relation(fields: [userId], references: [id])
  event    Event         @relation(fields: [eventId], references: [id])
  category SeatCategory  @relation(fields: [categoryId], references: [id])

  @@map("waitlist")
}
